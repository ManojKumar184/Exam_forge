NODE_ENV=development
PORT=5000

# MongoDB Atlas (or local)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/examforge?retryWrites=true&w=majority

# Local file uploads (Phase 2 — Cloudinary-ready architecture later)
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25

# JWT (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend (CORS)
CLIENT_URL=http://localhost:5173

# Optional: first super admin (created on seed)
SEED_ADMIN_EMAIL=admin@examforge.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# AI (Phase 4 — optional)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
